# Local dev configuration for screens.
# Copy to `.env` and uncomment any value you want to override.
# Real environment variables always take precedence over this file.

# --- HTTP server ---
HTTP_HOST=127.0.0.1
HTTP_PORT=8080

# --- Logging ---
# debug | info | warn | error
LOG_LEVEL=info
# Force colorized console logging. Auto-detected from TTY when unset.
DEV_MODE=true
